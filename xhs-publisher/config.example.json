{
  "platform": "xiaohongshu",
  "queueRoot": "/path/to/xhs-content-automation/social-publisher-queue",
  "userDataDir": "/path/to/xhs-content-automation/xhs-publisher/browser-profile",
  "browser": {
    "executablePath": "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome",
    "homeDir": "/path/to/xhs-content-automation/xhs-publisher/browser-home",
    "viewport": {
      "width": 1440,
      "height": 900
    }
  },
  "headless": false,
  "dryRun": true,
  "authPauseOnFailure": true,
  "requireImage": true,
  "appendTagsToText": true,
  "defaultTags": [],
  "timing": {
    "navigationTimeoutMs": 45000,
    "publishNavigationTimeoutMs": 90000,
    "postPublishWaitMs": 8000,
    "preBrowseEnabled": true,
    "postBrowseEnabled": true,
    "browseMinDurationMs": 10000,
    "browseScrollsMin": 3,
    "browseScrollsMax": 6,
    "browseOpenNotesMin": 2,
    "browseOpenNotesMax": 3,
    "inNoteScrollsMin": 1,
    "inNoteScrollsMax": 2,
    "noteStayMsMin": 5000,
    "noteStayMsMax": 10000,
    "scrollDistanceMin": 320,
    "scrollDistanceMax": 980,
    "browsePauseMsMin": 1500,
    "browsePauseMsMax": 3500
  },
  "selectors": {
    "publishUrl": "https://creator.xiaohongshu.com/publish/publish?source=official"
  }
}
